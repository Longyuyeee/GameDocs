        color: deepskyblue;
    }
    .nav-hot, .nav-persons, .nav-locations, .nav-sources {
        display: inline-block;
        position: relative;
    }
    .nav-hot:after, .nav-persons:after, .nav-locations:after, .nav-sources:after {
        font-family: 'icomoon';
        font-weight: normal;
        margin-left: 10px;
