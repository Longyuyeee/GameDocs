        padding: .2rem 1rem;
    }
    .big_info_menu .nav-item {
        float: left;
        width: 25%;
    }
    .big_info_menu .nav-item-title .nav-link, .big_info_menu .nav-item-title span {
        font-size: 1.4rem;
    }
    .big_info_menu .nav-hot {
